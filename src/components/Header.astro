---
import { SITE_TITLE } from "../consts";
---

<header class="bg-neutral-900 text-center pt-16 pb-12 px-4">
  <a href={import.meta.env.BASE_URL}>
    <h1
      class="text-4xl md:text-5xl font-serif tracking-[0.2em] text-white cursor-pointer hover:text-neutral-300 transition-colors"
    >
      {SITE_TITLE}
    </h1>
  </a>
  <p class="text-neutral-400 text-xs tracking-widest mt-4 uppercase">
    ロボットとかいろいろと。
  </p>
</header>
