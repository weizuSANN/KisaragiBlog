---
/**
 * Giscus Comment Component
 *
 * 下記の data-repo, data-repo-id, data-category, data-category-id は
 * https://giscus.app/ja で生成した値を貼り付けてください。
 */
---

<section class="giscus-container mt-16 pt-12 border-t border-neutral-300">
  <div class="max-w-prose mx-auto">
    <script
      src="https://giscus.app/client.js"
      data-repo="weizuSANN/KisaragiBlog"
      data-repo-id="R_kgDOSGBtow"
      data-category="Announcements"
      data-category-id="DIC_kwDONGqGms4Cj_aP"
      data-mapping="pathname"
      data-strict="0"
      data-reactions-enabled="1"
      data-emit-metadata="0"
      data-input-position="bottom"
      data-theme="light"
      data-lang="ja"
      data-loading="lazy"
      crossorigin="anonymous"
      async
    ></script>
  </div>
</section>

<style>
  .giscus-container {
    width: 100%;
    animation: fadeIn 0.8s ease-out forwards;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
