---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const navItems = [
  { name: 'Top', href: `${base}/` },
  { name: 'Profile', href: `${base}/profile` },
  { name: 'Information', href: `${base}/information` },
  { name: 'Blog', href: `${base}/blog` },
  { name: 'Gallery', href: `${base}/gallery` },
];

const { pathname } = Astro.url;
const subpath = pathname.match(/[^\/]+/g);
const isActive = (href: string) => {
    // Exact match for the base path
    if (href === `${base}/` || href === base) {
        return pathname === `${base}/` || pathname === base;
    }
    return pathname.startsWith(href);
};
---

<nav class="border-b border-neutral-300 bg-neutral-200">
  <div class="flex flex-col md:flex-row justify-between items-center px-4 md:px-8">
    <ul class="flex flex-wrap justify-center items-center">
      {navItems.map((item, index) => (
        <li class="flex items-center">
          <a 
            href={item.href} 
            class:list={[
                "px-4 md:px-6 py-4 text-sm tracking-widest transition-all duration-300",
                isActive(item.href) ? "text-neutral-900 bg-neutral-300 font-bold" : "text-neutral-600 hover:text-neutral-900 hover:bg-neutral-300"
            ]}
          >
            {item.name}
          </a>
          {index < navItems.length - 1 && (
            <span class="text-neutral-400 hidden sm:inline">|</span>
          )}
        </li>
      ))}
    </ul>

    {/* Search Bar - Static for now to match UI */}
    <div class="flex items-center relative py-3 md:py-0 w-full md:w-auto pb-4 md:pb-0">
      <input 
        id="global-search"
        type="text" 
        placeholder="Search..." 
        class="w-full md:w-48 bg-white border border-neutral-300 text-sm px-3 py-1.5 focus:outline-none focus:border-neutral-500 transition-colors text-neutral-800 placeholder-neutral-400"
      />
      <div class="absolute right-2 text-neutral-400 pointer-events-none">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-search"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
      </div>
    </div>
  </div>
</nav>

<script is:inline define:vars={{ base }}>
  const searchInput = document.getElementById('global-search');
  if (searchInput) {
    searchInput.addEventListener('keypress', (e) => {
      if (e.key === 'Enter') {
        const query = searchInput.value.trim();
        if (query) {
          window.location.href = `${base}/blog?q=${encodeURIComponent(query)}`;
        }
      }
    });
  }
</script>
