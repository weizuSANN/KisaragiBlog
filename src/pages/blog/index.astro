---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import { Tag as TagIcon } from 'lucide-astro';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<BaseLayout title="Blog | KisaragiLab">
	<div class="space-y-12 animate-fade-in">
		<div class="text-center space-y-4">
			<h2 class="text-2xl font-serif tracking-widest text-neutral-800 border-b border-neutral-300 pb-4 inline-block px-8">Blog</h2>
			<p class="text-neutral-500 text-sm leading-relaxed mt-6">
				日々の出来事や技術的な備忘録、制作の裏側などを綴っています。
			</p>
		</div>

		{/* Blog List */}
		<div class="space-y-12 mt-12">
			{posts.length > 0 ? (
				posts.map((post) => (
					<article class="group border-b border-neutral-200 pb-10 last:border-0">
						<a href={`/blog/${post.id}/`} class="block space-y-4">
							<div class="flex items-center space-x-4 text-xs font-mono text-neutral-400">
								<span><FormattedDate date={post.data.pubDate} /></span>
								{/* Placeholder for tags if they existed in the schema */}
								{post.data.tags && (
									<div class="flex gap-2">
										{post.data.tags.map((tag) => (
											<span class="flex items-center gap-0.5"><TagIcon size={10} />{tag}</span>
										))}
									</div>
								)}
							</div>
							<h3 class="text-2xl font-serif text-neutral-800 group-hover:text-neutral-500 transition-colors duration-300">
								{post.data.title}
							</h3>
							<p class="text-neutral-600 text-sm leading-relaxed line-clamp-2 italic font-serif">
								{post.data.description}
							</p>
							<div class="text-xs text-neutral-400 font-serif tracking-widest uppercase group-hover:text-neutral-800 transition-colors duration-300 flex items-center gap-2">
								Read More <span class="group-hover:translate-x-1 transition-transform duration-300">→</span>
							</div>
						</a>
					</article>
				))
			) : (
				<div class="text-center py-20 text-neutral-400 italic font-serif">
					No posts found.
				</div>
			)}
		</div>
	</div>
</BaseLayout>
