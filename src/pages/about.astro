---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About Me | KisaragiLab" description="About the author and the lab.">
	<div class="space-y-12 animate-fade-in">
		<div class="text-center space-y-4">
			<h2 class="text-2xl font-serif tracking-widest text-neutral-800 border-b border-neutral-300 pb-4 inline-block px-8">About</h2>
			<p class="text-neutral-500 text-sm leading-relaxed mt-6 italic">
				このサイトについて
			</p>
		</div>

		<div class="prose prose-neutral mx-auto font-serif text-neutral-700 leading-relaxed text-lg">
			<p>
				こんにちは。
			</p>
			<p>
				ロボット製作やプログラミング、デザインなどを行っています。
				このブログでは、日々の活動や技術的な発見を記録しています。
			</p>
			
			<h3 class="text-xl font-serif text-neutral-800 mt-12 mb-6 border-l-4 border-neutral-800 pl-4">Profile</h3>
			<ul class="space-y-2 list-none p-0">
				<li><strong>Name:</strong> Kisaragi</li>
				<li><strong>Interest:</strong> Embedded Systems, Web Development, Robotics</li>
				<li><strong>Tools:</strong> Next.js, Astro, C++, Python</li>
			</ul>

			<h3 class="text-xl font-serif text-neutral-800 mt-12 mb-6 border-l-4 border-neutral-800 pl-4">Links</h3>
			<ul class="space-y-2 list-none p-0">
				<li>
					<a href="https://twitter.com/Kaede_Reape0430" class="text-neutral-600 hover:text-neutral-900 underline decoration-neutral-300 underline-offset-4 transition-colors">Twitter</a>
				</li>
				<li>
					<a href="https://github.com/weizuSANN" class="text-neutral-600 hover:text-neutral-900 underline decoration-neutral-300 underline-offset-4 transition-colors">GitHub</a>
				</li>
			</ul>
		</div>
	</div>
</BaseLayout>
