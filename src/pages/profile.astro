---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Profile | KisaragiLab" description="About グリムリーパー">
	<div class="space-y-12 animate-fade-in">
		<div class="text-center space-y-4">
			<h2 class="text-3xl font-serif tracking-[0.3em] text-neutral-800 border-b border-neutral-300 pb-6 inline-block px-12 uppercase">
				Profile
			</h2>
		</div>

		<div class="flex flex-col md:flex-row items-center md:items-start gap-12 max-w-3xl mx-auto py-8">
			{/* Avatar Placeholder */}
			<div class="w-48 h-48 bg-neutral-200 rounded-full flex-shrink-0 shadow-inner overflow-hidden border border-neutral-300">
				<div class="w-full h-full flex items-center justify-center text-neutral-400">
					<svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-user"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
				</div>
			</div>

			<div class="flex-grow space-y-6 text-neutral-700 leading-relaxed font-serif">
				<div class="space-y-2">
					<p class="text-lg font-bold text-neutral-800">Name: グリムリーパー</p>
				</div>
				
				<div class="space-y-4 text-sm">
					<p>
						産技高専でロボットとかやってるタイプの人。
					</p>
					<p>
						趣味は開発。常に何らかの開発や設計をしていないと死んでしまうので何かしらを作り続けている。ロボットとか電子工作とかの開発のほか、ゲーム制作、音楽、お絵描きその他なんでもやってみたさはあるので、常に時間も能力も足りていない。
					</p>
					<p>
						研究者になりたいです。
					</p>
					<p>
						ご依頼やご相談は、SNSのDMよりお気軽にご連絡ください。ブログの関連ならコメントでも可。
					</p>
				</div>
			</div>
		</div>

		<div class="flex justify-center pt-8 border-t border-neutral-200">
			<a href="https://twitter.com/Kaede_Reape0430" class="text-neutral-500 hover:text-neutral-900 transition-colors" aria-label="Twitter">
				<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-twitter"><path d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z"/></svg>
			</a>
		</div>
	</div>
</BaseLayout>
